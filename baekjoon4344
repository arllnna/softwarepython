t = int(input())

for _ in range(t):
    arr = list(map(int, input().split()))
    
    n = arr[0]
    scores = arr[1:]
    
    avg = sum(scores) / n
    
    count = 0
    for s in scores:
        if s > avg:
            count += 1
    
    percent = count / n * 100
    
    print(f"{percent:.3f}%")
