t = int(input())

for _ in range(t):
    s = input().strip()
    stack = []

    for ch in s:
        if ch == '(':
            stack.append(ch)
        else:  # ')'
            if stack:
                stack.pop()
            else:
                stack.append(ch)
                break

    if not stack:
        print("YES")
    else:
        print("NO")
